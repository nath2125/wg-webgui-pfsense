# ===========================================================================
#  WireGuard Web-Interface — configuration
#  Copy to .env and fill in. NOTHING here has a hardcoded default secret.
# ===========================================================================

# Optional UI name.
APP_NAME=WireGuard Web-Interface

# --- pfSense REST API (jaredhendrickson13/pfSense-pkg-RESTAPI v2) -----------
# OPTIONAL: leave these blank to onboard from the browser instead. With SETUP_FILE
# set (below), an unconfigured app boots into a /setup wizard where you enter the URL
# + API key, pick your tunnel, and import existing peers — no file editing needed.
PFSENSE_API_URL=https://192.168.1.1
PFSENSE_API_KEY=replace-with-your-api-key
PFSENSE_VERIFY_TLS=false
PFSENSE_TIMEOUT=15

# --- WireGuard tunnel / endpoint -------------------------------------------
WG_TUNNEL=tun_wg0
WG_ENDPOINT_HOST=vpn.example.com
WG_ENDPOINT_PORT=51820
# Leave blank to auto-discover the tunnel's public key from pfSense at startup.
WG_SERVER_PUBLIC_KEY=
# DNS pushed to clients (blank = omit the DNS line).
WG_CLIENT_DNS=
WG_PERSISTENT_KEEPALIVE=25
WG_CLIENT_MTU=0

# Default client-side AllowedIPs = ROUTING ONLY (what the client sends into the
# tunnel). This is NOT access control — you set firewall/ACL rules in pfSense.
# 0.0.0.0/0 = full tunnel. For split tunnel, list your subnets, e.g.
#   WG_CLIENT_ALLOWED_IPS=192.168.10.0/24, 192.168.90.0/24
WG_CLIENT_ALLOWED_IPS=0.0.0.0/0
# Optional suggestions shown in the add form (JSON list of strings).
# WG_ALLOWEDIPS_PRESETS=["0.0.0.0/0","192.168.0.0/16","192.168.90.0/24"]
WG_ALLOWEDIPS_PRESETS=

# --- IP pool for peer /32 allocation ---------------------------------------
# The app hands out the next free /32 here, checked against EXISTING pfSense peers.
IP_POOL_CIDR=192.168.90.0/24
IP_POOL_START=
IP_POOL_END=
IP_POOL_RESERVED=

# --- Admin auth (single gate on the whole UI) ------------------------------
ADMIN_USERNAME=admin
# Preferred: an scrypt hash (password never stored in plaintext). Generate with:
#   python -m app.hashpw
# If ADMIN_PASSWORD_HASH is set it takes precedence over ADMIN_PASSWORD.
ADMIN_PASSWORD_HASH=
# Fallback plaintext password (fine behind your proxy; hash is better).
ADMIN_PASSWORD=replace-with-a-strong-password
# Writable file for the scrypt hash; enables the in-UI "Change password" button.
ADMIN_PASSWORD_FILE=
# Optional 2FA (TOTP). Point at a writable file to enable the in-UI 2FA setup button;
# blank = 2FA hidden/disabled.
TOTP_FILE=
# Onboarding: a writable file the /setup wizard writes the pfSense connection to. Set
# this to let a fresh instance be configured from the browser (see the pfSense section).
# In Docker use the mounted data dir, e.g. /data/setup.json.
SETUP_FILE=
# Random string for signing the session cookie. Generate with:
#   python -c "import secrets;print(secrets.token_urlsafe(48))"
SESSION_SECRET=replace-with-a-long-random-string
SESSION_MAX_AGE=28800
# Set true when served over HTTPS (adds Secure flag / HSTS).
SESSION_HTTPS_ONLY=false
ENABLE_HSTS=false
# Brute-force lockout: after N failures from an IP, lock it for M seconds.
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=300
# Only set true when a reverse proxy you control sits in front. It makes the
# lockout key off X-Forwarded-For; if nothing strips that header, a client can
# vary it per request and never trip the lockout.
TRUST_PROXY_HEADERS=false
# FastAPI's /docs, /redoc and /openapi.json cannot be auth-gated and describe the
# whole admin API to anyone who can reach the port. Leave false in production.
ENABLE_API_DOCS=false

# --- Config delivery -------------------------------------------------------
# Public base URL used to build one-time links (blank = derived from the request).
PUBLIC_BASE_URL=
# One-time link lifetime (minutes). Links are single-use and encrypted at rest.
LINK_TTL_MINUTES=30
# SMTP email delivery. Leave SMTP_HOST blank to hide the "Email" option.
# NOTE: emailing a config sends the private key through the server and into an
# inbox — a deliberate weakening of the "key never touches the server" model.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true
SMTP_SSL=false

# --- Apply debounce --------------------------------------------------------
APPLY_DEBOUNCE_SECONDS=2

# --- Storage ---------------------------------------------------------------
DATABASE_URL=sqlite:////data/devices.db
